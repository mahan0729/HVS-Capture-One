<Window x:Class="HVSCaptureOne.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HVS Capture One"
        Height="768" Width="1024"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Banner -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryAccentBrush}">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="24,0">
                <Image Source="/Assets/hvs_logo.png"
                       Height="40" Width="40"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="HVS Capture One"
                           FontSize="22"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Main Content Area — swaps between views via DataTemplates -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentView}"
                        Margin="0" />
    </Grid>
</Window>
