<UserControl x:Class="HVSCaptureOne.App.Views.EditProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Status -->
            <RowDefinition Height="Auto" />  <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryAccentBrush}"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource StepHeader}" Text="Edit Project" />
                <TextBlock Style="{StaticResource StepHeader}"
                           Text=" — "
                           Opacity="0.6" />
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="{Binding ProjectId}"
                           Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Content: left = read-only, right = editable -->
        <Grid Grid.Row="1" Margin="32,24,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: read-only info -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Project Info -->
                    <TextBlock Text="Project"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               Margin="0,0,0,8" />
                    <Border Background="#F9F9F9"
                            BorderBrush="{StaticResource LightBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="16,12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project ID"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProjectId}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Project Name"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectName}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Created"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedDate}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Output Folder"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OutputFolder}"
                                       Style="{StaticResource BodyLabel}" TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <!-- File Info -->
                    <TextBlock Text="Source File"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               Margin="0,0,0,8" />
                    <Border Background="#F9F9F9"
                            BorderBrush="{StaticResource LightBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="File Path"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}"
                                       Style="{StaticResource BodyLabel}" TextWrapping="Wrap" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Output File"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OutputFile}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Resolution"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Resolution}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Codec"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Codec}"
                                       Style="{StaticResource BodyLabel}" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Duration"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Duration}"
                                       Style="{StaticResource BodyLabel}" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT: editable fields -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Client Info -->
                    <TextBlock Text="Client"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               Margin="0,0,0,8" />
                    <Border Background="#F9F9F9"
                            BorderBrush="{StaticResource LightBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="16,12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Client Name"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Client Email"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <!-- Metadata -->
                    <TextBlock Text="Metadata"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               Margin="0,0,0,8" />
                    <Border Background="#F9F9F9"
                            BorderBrush="{StaticResource LightBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="16,12" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Main Title"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding MainTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Sub Title"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding SubTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Description"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="72"
                                     VerticalContentAlignment="Top"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Tape ID"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding OriginalTapeId, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Notes (internal — not embedded)"
                                       Style="{StaticResource BodyLabel}" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource FormTextBox}"
                                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="60"
                                     VerticalContentAlignment="Top" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status panel -->
        <Border Grid.Row="2"
                Margin="32,12,32,0"
                Padding="14,10"
                CornerRadius="6"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                            <Setter Property="Visibility"   Value="Visible" />
                            <Setter Property="Background"   Value="{StaticResource DragDropBackgroundBrush}" />
                            <Setter Property="BorderBrush"  Value="{StaticResource LightBorderBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsComplete}" Value="True">
                            <Setter Property="Visibility"   Value="Visible" />
                            <Setter Property="Background"   Value="#F0FFF4" />
                            <Setter Property="BorderBrush"  Value="{StaticResource SuccessGreenBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility"   Value="Visible" />
                            <Setter Property="Background"   Value="#FFF0F0" />
                            <Setter Property="BorderBrush"  Value="{StaticResource ErrorRedBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ProcessingStatus}"
                       Style="{StaticResource BodyLabel}"
                       TextWrapping="Wrap"
                       FontSize="13" />
        </Border>

        <!-- Footer: Cancel + Reprocess -->
        <Border Grid.Row="3"
                Background="#F0F0F0"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,14">
            <Grid>
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Left"
                        Padding="10,6">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Width="27" Height="27" Stretch="Uniform" Fill="Black"
                              Data="M61.44,0c33.926,0,61.44,27.514,61.44,61.44c0,33.926-27.514,61.439-61.44,61.439C27.513,122.88,0,95.366,0,61.44C0,27.514,27.513,0,61.44,0z M98.505,37.049L37.051,98.503c6.999,4.617,15.379,7.307,24.389,7.307c24.5,0,44.369-19.869,44.369-44.369C105.809,52.431,103.119,44.05,98.505,37.049z M24.378,85.829l61.453-61.454c-6.997-4.615-15.381-7.304-24.391-7.304c-24.5,0-44.369,19.87-44.369,44.369C17.072,70.449,19.761,78.83,24.378,85.829z" />
                        <TextBlock Text="Cancel"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="11"
                                   Foreground="Black"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button Content="{Binding ReprocessButtonText}"
                        Command="{Binding ReprocessCommand}"
                        IsEnabled="{Binding CanReprocess}"
                        HorizontalAlignment="Right"
                        Padding="16,6" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
