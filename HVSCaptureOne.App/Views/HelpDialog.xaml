<Window x:Class="HVSCaptureOne.App.Views.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help"
        Width="420" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Message area -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Work In Progress"
                       FontFamily="{StaticResource MontserratFont}"
                       FontWeight="Bold"
                       FontSize="26"
                       Foreground="{StaticResource HeadingTextBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="This is coming soon."
                       FontFamily="{StaticResource LatoFont}"
                       FontSize="14"
                       FontStyle="Italic"
                       Foreground="{StaticResource BodyTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />
        </StackPanel>

        <!-- Footer with Exit button -->
        <Border Grid.Row="1"
                Background="#F0F0F0"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Padding="10,6"
                    Click="CloseButton_Click">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="27" Height="27">
                        <Image Source="/Assets/Exit.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                    </Grid>
                    <TextBlock Text="Exit"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="11"
                               Foreground="Black"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</Window>
