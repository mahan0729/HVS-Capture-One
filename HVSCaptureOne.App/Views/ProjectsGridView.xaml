<UserControl x:Class="HVSCaptureOne.App.Views.ProjectsGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>

        <!-- Compact action buttons for the grid rows -->
        <Style x:Key="GridBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="{StaticResource MontserratFont}" />
            <Setter Property="FontWeight"      Value="Bold" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="Black" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="10,4" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Margin"          Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridEditBtn"   TargetType="Button" BasedOn="{StaticResource GridBtn}" />
        <Style x:Key="GridSaveBtn"   TargetType="Button" BasedOn="{StaticResource GridBtn}" />
        <Style x:Key="GridCancelBtn" TargetType="Button" BasedOn="{StaticResource GridBtn}" />
        <Style x:Key="GridDeleteBtn" TargetType="Button" BasedOn="{StaticResource GridBtn}" />

        <!-- DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#F0F0F0" />
            <Setter Property="Foreground"    Value="{StaticResource HeadingTextBrush}" />
            <Setter Property="FontFamily"    Value="{StaticResource MontserratFont}" />
            <Setter Property="FontWeight"    Value="Bold" />
            <Setter Property="FontSize"      Value="12" />
            <Setter Property="Padding"       Value="8,8" />
            <Setter Property="BorderBrush"   Value="{StaticResource LightBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <!-- DataGrid cell — remove default blue selection highlight -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"           Value="0" />
            <Setter Property="BorderThickness"   Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Foreground"  Value="{StaticResource HeadingTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="42" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF7FD" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Reusable read-mode cell TextBlock style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Padding"           Value="6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming"      Value="CharacterEllipsis" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryAccentBrush}"
                Padding="24,14">
            <Grid>
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="Video Library"
                           VerticalAlignment="Center" />
                <TextBlock FontFamily="{StaticResource LatoFont}"
                           FontSize="13"
                           Foreground="White"
                           Opacity="0.85"
                           Text="{Binding HeaderLabel}"
                           Visibility="{Binding HeaderLabelVisibility}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding NewProjectCommand}"
                        HorizontalAlignment="Right"
                        Padding="10,6">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Width="36" Height="36" Stretch="Uniform" Fill="Black"
                              Data="M104.885,17.995c23.993,23.994,23.993,62.896,0,86.89c-23.994,23.993-62.896,23.993-86.89,0c-23.993-23.994-23.993-62.896,0-86.89C41.989-5.998,80.891-5.998,104.885,17.995z M93.607,57.949c1.928,0,3.49,1.563,3.49,3.49c0,1.928-1.563,3.49-3.49,3.49H64.93v28.678c0,1.928-1.563,3.49-3.49,3.49c-1.927,0-3.489-1.563-3.489-3.49V64.93H29.272c-1.928,0-3.491-1.563-3.491-3.49c0-1.927,1.563-3.49,3.491-3.49H57.95V29.271c0-1.927,1.563-3.49,3.489-3.49c1.928,0,3.49,1.563,3.49,3.49v28.678H93.607z" />
                        <TextBlock Text="+ New Project"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="11"
                                   Foreground="Black"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Content area ───────────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- DataGrid — shown when rows exist -->
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="True"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource LightBorderBrush}"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="{StaticResource DragDropBackgroundBrush}"
                      BorderBrush="{StaticResource LightBorderBrush}"
                      BorderThickness="0,1,0,0"
                      FontFamily="{StaticResource LatoFont}"
                      FontSize="14"
                      Foreground="{StaticResource HeadingTextBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding HasRows, Converter={StaticResource BoolToVisibilityConverter}}">

                <DataGrid.Columns>

                    <!-- Project ID -->
                    <DataGridTextColumn Header="Project ID"
                                        Binding="{Binding ProjectId}"
                                        Width="130"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Client Name — editable -->
                    <DataGridTemplateColumn Header="Client Name" Width="145">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding ClientName}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Client Email — editable -->
                    <DataGridTemplateColumn Header="Email" Width="185">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding ClientEmail}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Main Title — editable -->
                    <DataGridTemplateColumn Header="Main Title" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding MainTitle}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding MainTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Sub Title — editable -->
                    <DataGridTemplateColumn Header="Sub Title" Width="125">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding SubTitle}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding SubTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Description — editable -->
                    <DataGridTemplateColumn Header="Description" Width="125">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding Description}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding Date}"
                                        Width="92"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Status -->
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="82"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Output File -->
                    <DataGridTextColumn Header="Output File"
                                        Binding="{Binding OutputFile}"
                                        Width="155"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="205" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="6,4">
                                    <!-- Edit (read mode only) -->
                                    <Button Style="{StaticResource GridEditBtn}"
                                            Command="{Binding EditCommand}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Width="20" Height="20">
                                                <Image Source="/Assets/Edit.png"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                                            </Grid>
                                            <TextBlock Text="Edit"
                                                       FontFamily="{StaticResource MontserratFont}"
                                                       FontSize="10"
                                                       Foreground="Black"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <!-- Save (edit mode only) -->
                                    <Button Content="Save"
                                            Style="{StaticResource GridSaveBtn}"
                                            Command="{Binding SaveEditCommand}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Cancel (edit mode only) -->
                                    <Button Style="{StaticResource GridCancelBtn}"
                                            Command="{Binding CancelEditCommand}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Path Width="20" Height="20" Stretch="Uniform" Fill="Black"
                                                  Data="M61.44,0c33.926,0,61.44,27.514,61.44,61.44c0,33.926-27.514,61.439-61.44,61.439C27.513,122.88,0,95.366,0,61.44C0,27.514,27.513,0,61.44,0z M98.505,37.049L37.051,98.503c6.999,4.617,15.379,7.307,24.389,7.307c24.5,0,44.369-19.869,44.369-44.369C105.809,52.431,103.119,44.05,98.505,37.049z M24.378,85.829l61.453-61.454c-6.997-4.615-15.381-7.304-24.391-7.304c-24.5,0-44.369,19.87-44.369,44.369C17.072,70.449,19.761,78.83,24.378,85.829z" />
                                            <TextBlock Text="Cancel"
                                                       FontFamily="{StaticResource MontserratFont}"
                                                       FontSize="10"
                                                       Foreground="Black"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <!-- Delete (always visible) -->
                                    <Button Style="{StaticResource GridDeleteBtn}"
                                            Command="{Binding DeleteCommand}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Grid Width="20" Height="20">
                                                <Image Source="/Assets/Delete.png"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                                            </Grid>
                                            <TextBlock Text="Delete"
                                                       FontFamily="{StaticResource MontserratFont}"
                                                       FontSize="10"
                                                       Foreground="Black"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state — shown when no rows exist -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource BodyLabel}"
                           Text="No videos on record yet."
                           HorizontalAlignment="Center"
                           FontSize="20"
                           Margin="0,0,0,10" />
                <TextBlock Style="{StaticResource BodyLabel}"
                           Text="Click + New Project above to get started."
                           HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

        <!-- ── Footer bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Button Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Right"
                    Padding="10,6">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="27" Height="27">
                        <Image Source="/Assets/Exit.png"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                    </Grid>
                    <TextBlock Text="Exit"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="11"
                               Foreground="Black"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </Border>

    </Grid>
</UserControl>
