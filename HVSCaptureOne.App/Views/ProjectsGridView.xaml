<UserControl x:Class="HVSCaptureOne.App.Views.ProjectsGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>

        <!-- Compact action buttons for the grid rows -->
        <Style x:Key="GridBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="{StaticResource MontserratFont}" />
            <Setter Property="FontWeight"      Value="Bold" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="10,4" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Margin"          Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridEditBtn"   TargetType="Button" BasedOn="{StaticResource GridBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
        </Style>
        <Style x:Key="GridSaveBtn"   TargetType="Button" BasedOn="{StaticResource GridBtn}">
            <Setter Property="Background" Value="{StaticResource SuccessGreenBrush}" />
        </Style>
        <Style x:Key="GridCancelBtn" TargetType="Button" BasedOn="{StaticResource GridBtn}">
            <Setter Property="Background" Value="{StaticResource BodyTextBrush}" />
        </Style>
        <Style x:Key="GridDeleteBtn" TargetType="Button" BasedOn="{StaticResource GridBtn}">
            <Setter Property="Background" Value="{StaticResource ErrorRedBrush}" />
        </Style>

        <!-- DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#F0F0F0" />
            <Setter Property="Foreground"    Value="{StaticResource HeadingTextBrush}" />
            <Setter Property="FontFamily"    Value="{StaticResource MontserratFont}" />
            <Setter Property="FontWeight"    Value="Bold" />
            <Setter Property="FontSize"      Value="12" />
            <Setter Property="Padding"       Value="8,8" />
            <Setter Property="BorderBrush"   Value="{StaticResource LightBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <!-- DataGrid cell — remove default blue selection highlight -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"           Value="0" />
            <Setter Property="BorderThickness"   Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Foreground"  Value="{StaticResource HeadingTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="42" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF7FD" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Reusable read-mode cell TextBlock style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Padding"           Value="6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming"      Value="CharacterEllipsis" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryAccentBrush}"
                Padding="24,14">
            <Grid>
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="HVS Capture One — Video Library"
                           VerticalAlignment="Center" />
                <Button Style="{StaticResource CtaButton}"
                        Content="+ New Project"
                        Command="{Binding NewProjectCommand}"
                        HorizontalAlignment="Right"
                        FontSize="14"
                        Padding="20,8" />
            </Grid>
        </Border>

        <!-- ── Content area ───────────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- DataGrid — shown when rows exist -->
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="True"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource LightBorderBrush}"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="{StaticResource DragDropBackgroundBrush}"
                      BorderBrush="{StaticResource LightBorderBrush}"
                      BorderThickness="0,1,0,0"
                      FontFamily="{StaticResource LatoFont}"
                      FontSize="14"
                      Foreground="{StaticResource HeadingTextBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding HasRows, Converter={StaticResource BoolToVisibilityConverter}}">

                <DataGrid.Columns>

                    <!-- Project ID -->
                    <DataGridTextColumn Header="Project ID"
                                        Binding="{Binding ProjectId}"
                                        Width="130"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Client Name — editable -->
                    <DataGridTemplateColumn Header="Client Name" Width="145">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding ClientName}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Client Email — editable -->
                    <DataGridTemplateColumn Header="Email" Width="185">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding ClientEmail}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Main Title — editable -->
                    <DataGridTemplateColumn Header="Main Title" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding MainTitle}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding MainTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Sub Title — editable -->
                    <DataGridTemplateColumn Header="Sub Title" Width="125">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding SubTitle}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding SubTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Description — editable -->
                    <DataGridTemplateColumn Header="Description" Width="125">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock Style="{StaticResource CellText}"
                                               Text="{Binding Description}"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <TextBox Style="{StaticResource FormTextBox}"
                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding Date}"
                                        Width="92"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Status -->
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="82"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Output File -->
                    <DataGridTextColumn Header="Output File"
                                        Binding="{Binding OutputFile}"
                                        Width="155"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="205" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="6,4">
                                    <!-- Edit (read mode only) — pencil icon -->
                                    <Button Style="{StaticResource GridEditBtn}"
                                            Command="{Binding EditCommand}"
                                            ToolTip="Edit"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="20" Height="20">
                                                <Path Fill="White"
                                                      Data="M 15,3 L 17,5 L 6,16 L 3,17 L 4,14 Z" />
                                                <Path Fill="White" Opacity="0.75"
                                                      Data="M 13,2 L 16,2 L 18,4 L 15,5 Z" />
                                                <Line X1="4" Y1="14" X2="6" Y2="16"
                                                      Stroke="White" StrokeThickness="1" Opacity="0.6" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <!-- Save (edit mode only) -->
                                    <Button Content="Save"
                                            Style="{StaticResource GridSaveBtn}"
                                            Command="{Binding SaveEditCommand}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Cancel (edit mode only) -->
                                    <Button Content="Cancel"
                                            Style="{StaticResource GridCancelBtn}"
                                            Command="{Binding CancelEditCommand}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- Delete (always visible) — trash can icon -->
                                    <Button Style="{StaticResource GridDeleteBtn}"
                                            Command="{Binding DeleteCommand}"
                                            ToolTip="Delete">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="20" Height="20">
                                                <!-- Handle -->
                                                <Path Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                                                      Data="M 8,1 L 8,3 L 12,3 L 12,1" />
                                                <!-- Lid -->
                                                <Line X1="3" Y1="4" X2="17" Y2="4"
                                                      Stroke="White" StrokeThickness="1.5" />
                                                <!-- Body -->
                                                <Path Stroke="White" StrokeThickness="1.5" Fill="Transparent"
                                                      Data="M 5,5 L 6,18 L 14,18 L 15,5 Z" />
                                                <!-- Slats -->
                                                <Line X1="8"  Y1="7" X2="8"  Y2="16" Stroke="White" StrokeThickness="1" Opacity="0.75" />
                                                <Line X1="10" Y1="7" X2="10" Y2="16" Stroke="White" StrokeThickness="1" Opacity="0.75" />
                                                <Line X1="12" Y1="7" X2="12" Y2="16" Stroke="White" StrokeThickness="1" Opacity="0.75" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state — shown when no rows exist -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource BodyLabel}"
                           Text="No videos on record yet."
                           HorizontalAlignment="Center"
                           FontSize="20"
                           Margin="0,0,0,10" />
                <TextBlock Style="{StaticResource BodyLabel}"
                           Text="Click + New Project above to get started."
                           HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

        <!-- ── Footer bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Button Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Right"
                    Padding="16,8"
                    ToolTip="Exit">
                <Viewbox Width="28" Height="28">
                    <!-- Door icon: frame, panel, knob, and exit arrow -->
                    <Canvas Width="24" Height="24">
                        <!-- Door frame (outer) -->
                        <Rectangle Canvas.Left="2"  Canvas.Top="1"
                                   Width="14" Height="22"
                                   Stroke="{StaticResource PrimaryAccentBrush}"
                                   StrokeThickness="1.5"
                                   Fill="Transparent" />
                        <!-- Door panel (inner, inset) -->
                        <Rectangle Canvas.Left="3.5" Canvas.Top="2.5"
                                   Width="11" Height="19"
                                   Stroke="{StaticResource PrimaryAccentBrush}"
                                   StrokeThickness="1"
                                   Fill="#EBF7FD" />
                        <!-- Doorknob -->
                        <Ellipse Canvas.Left="11" Canvas.Top="11"
                                 Width="3" Height="3"
                                 Fill="{StaticResource PrimaryAccentBrush}" />
                        <!-- Exit arrow (→) to the right of the door -->
                        <Path Stroke="{StaticResource PrimaryAccentBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M 18,12 L 22,12 M 19.5,10 L 22,12 L 19.5,14" />
                    </Canvas>
                </Viewbox>
            </Button>
        </Border>

    </Grid>
</UserControl>
