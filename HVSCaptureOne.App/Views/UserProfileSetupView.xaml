<UserControl x:Class="HVSCaptureOne.App.Views.UserProfileSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HVSCaptureOne.App.ViewModels"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="560" Margin="60,40" HorizontalAlignment="Left">

            <!-- Section Header -->
            <Border Background="{StaticResource PrimaryAccentBrush}"
                    CornerRadius="6" Padding="20,14" Margin="0,0,0,28">
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="Tell us about your studio"
                           FontSize="18" />
            </Border>

            <TextBlock Style="{StaticResource BodyLabel}"
                       Text="This information is saved once and applied to all future projects."
                       Margin="0,0,0,24" />

            <!-- First Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="First Name *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Last Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Last Name *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Company Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Company Name" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Address -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Address" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Phone -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Phone" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Email -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Email" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Validation Message -->
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{StaticResource ErrorRedBrush}"
                       FontFamily="{StaticResource LatoFont}"
                       FontSize="13"
                       Margin="0,12,0,0"
                       Visibility="{Binding ValidationMessage,
                                    Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Save Button -->
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Save &amp; Continue"
                    Command="{Binding SaveAndContinueCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,28,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
