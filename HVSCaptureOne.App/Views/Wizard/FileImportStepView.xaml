<UserControl x:Class="HVSCaptureOne.App.Views.Wizard.FileImportStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="560" Margin="60,32" HorizontalAlignment="Left">

            <!-- Section Header -->
            <Border Background="{StaticResource PrimaryAccentBrush}"
                    CornerRadius="6" Padding="20,12" Margin="0,0,0,24">
                <TextBlock Style="{StaticResource StepHeader}" Text="Import Video File" />
            </Border>

            <!-- Drag-Drop Zone -->
            <Border Background="{StaticResource DragDropBackgroundBrush}"
                    BorderBrush="{StaticResource LightBorderBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="40,36"
                    Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Drop an MP4 file here"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource BodyTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10" />
                    <TextBlock Text="— or —"
                               Style="{StaticResource BodyLabel}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Browse for File…"
                            Command="{Binding BrowseFileCommand}"
                            HorizontalAlignment="Center"
                            Padding="20,8" />
                </StackPanel>
            </Border>

            <!-- Error Status -->
            <Border Visibility="{Binding IsError, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#FFF0F0"
                    BorderBrush="{StaticResource ErrorRedBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,12">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource ErrorRedBrush}"
                           FontFamily="{StaticResource LatoFont}"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Success Status + File Info -->
            <Border Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#F0FFF4"
                    BorderBrush="{StaticResource SuccessGreenBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessGreenBrush}"
                               FontFamily="{StaticResource LatoFont}"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="File: "
                                   Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}"
                                   Style="{StaticResource BodyLabel}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution: "
                                   Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetectedResolution}"
                                   Style="{StaticResource BodyLabel}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Codec: "
                                   Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetectedCodec}"
                                   Style="{StaticResource BodyLabel}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Duration: "
                                   Style="{StaticResource BodyLabel}" FontWeight="Bold" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetectedDuration}"
                                   Style="{StaticResource BodyLabel}" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Only H.264 MP4 files up to 4K are accepted."
                       Margin="0,4,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
