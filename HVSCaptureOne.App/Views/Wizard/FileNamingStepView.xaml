<UserControl x:Class="HVSCaptureOne.App.Views.Wizard.FileNamingStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="560" Margin="60,32" HorizontalAlignment="Left">

            <!-- Section Header -->
            <Border Background="{StaticResource SecondaryAccentBrush}"
                    CornerRadius="6" Padding="20,12" Margin="0,0,0,24">
                <TextBlock Style="{StaticResource StepHeader}" Text="File Naming" />
            </Border>

            <!-- Suggested File Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Suggested File Name" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding SuggestedFileName, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#F5F5F5"
                     Foreground="{StaticResource BodyTextBrush}"
                     Margin="0,0,0,20" />

            <!-- Naming Options -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Choose naming option" />

            <RadioButton Content="Use suggested name"
                         IsChecked="{Binding UseSuggestedName}"
                         FontFamily="{StaticResource LatoFont}"
                         FontSize="14"
                         Foreground="{StaticResource HeadingTextBrush}"
                         Margin="0,8,0,8" />

            <RadioButton Content="Enter a custom name"
                         IsChecked="{Binding UseSuggestedName,
                                             Converter={StaticResource InverseBoolConverter},
                                             Mode=TwoWay}"
                         FontFamily="{StaticResource LatoFont}"
                         FontSize="14"
                         Foreground="{StaticResource HeadingTextBrush}"
                         Margin="0,0,0,16" />

            <!-- Custom Name Input (visible only when custom is selected) -->
            <StackPanel Visibility="{Binding UseSuggestedName,
                                             Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Custom File Name" />
                <TextBox Style="{StaticResource FormTextBox}"
                         Text="{Binding CustomFileName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource HintLabel}"
                           Text="Do not include the .mp4 extension." />
            </StackPanel>

            <!-- Effective Name Preview -->
            <Border Background="{StaticResource DragDropBackgroundBrush}"
                    BorderBrush="{StaticResource LightBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Output file: "
                               FontFamily="{StaticResource LatoFont}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeadingTextBrush}" />
                    <TextBlock FontFamily="{StaticResource LatoFont}"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryAccentBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}.mp4">
                                <Binding Path="EffectiveFileName" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
