<UserControl x:Class="HVSCaptureOne.App.Views.Wizard.MetadataFormStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="560" Margin="60,32" HorizontalAlignment="Left">

            <!-- Section Header -->
            <Border Background="{StaticResource SecondaryAccentBrush}"
                    CornerRadius="6" Padding="20,12" Margin="0,0,0,24">
                <TextBlock Style="{StaticResource StepHeader}" Text="Video Metadata" />
            </Border>

            <!-- Main Display Title (required) -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Main Display Title *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding MainTitle, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Embedded as ttl1 and dvat atoms."
                       Margin="0,4,0,0" />

            <!-- Sub Display Title -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Sub Display Title" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding SubTitle, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Embedded as the ttls atom."
                       Margin="0,4,0,0" />

            <!-- Video Description -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Video Description" />
            <TextBox Style="{StaticResource MultiLineTextBox}"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     MinLines="4"
                     MaxLines="8" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Embedded as the ttld atom."
                       Margin="0,4,0,0" />

            <!-- Original Tape ID -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Original Tape ID" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding OriginalTapeId, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Stored in the project record only — not embedded in the output file."
                       Margin="0,4,0,0" />

            <!-- Internal Notes -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Internal Notes" />
            <TextBox Style="{StaticResource MultiLineTextBox}"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     MinLines="3"
                     MaxLines="6" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="Internal notes — not embedded in the output file."
                       Margin="0,4,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
