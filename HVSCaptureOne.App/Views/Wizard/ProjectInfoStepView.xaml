<UserControl x:Class="HVSCaptureOne.App.Views.Wizard.ProjectInfoStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="560" Margin="60,32" HorizontalAlignment="Left">

            <!-- Section Header -->
            <Border Background="{StaticResource PrimaryAccentBrush}"
                    CornerRadius="6" Padding="20,12" Margin="0,0,0,24">
                <TextBlock Style="{StaticResource StepHeader}" Text="Project Information" />
            </Border>

            <!-- Project Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Project Name *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Client First Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Client First Name *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding ClientFirstName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Client Last Name -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Client Last Name *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding ClientLastName, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Client Email -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Client Email *" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding ClientEmail, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Text="{Binding EmailError}"
                       Foreground="{StaticResource ErrorRedBrush}"
                       FontFamily="{StaticResource LatoFont}"
                       FontSize="13"
                       Margin="0,3,0,0"
                       Visibility="{Binding EmailError, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Project ID (read-only) -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Project ID (auto-generated)" />
            <TextBox Style="{StaticResource FormTextBox}"
                     Text="{Binding GeneratedProjectId, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#F5F5F5"
                     Foreground="{StaticResource BodyTextBrush}" />
            <TextBlock Style="{StaticResource HintLabel}"
                       Text="This ID is embedded in the output file as the tpnm atom."
                       Margin="0,4,0,0" />

            <!-- Output Folder -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Output Folder *" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource FormTextBox}"
                         Text="{Binding OutputFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BrowseOutputFolderCommand}"
                        Padding="10,6">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="36" Height="36">
                            <Image Source="/Assets/browse.png"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                        </Grid>
                        <TextBlock Text="Browse"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="11"
                                   Foreground="Black"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
