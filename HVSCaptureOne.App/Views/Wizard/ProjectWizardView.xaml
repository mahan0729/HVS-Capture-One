<UserControl x:Class="HVSCaptureOne.App.Views.Wizard.ProjectWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmw="clr-namespace:HVSCaptureOne.App.ViewModels.Wizard"
             xmlns:vw="clr-namespace:HVSCaptureOne.App.Views.Wizard"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>
        <!-- Step DataTemplates scoped to the wizard -->
        <DataTemplate DataType="{x:Type vmw:ProjectInfoStepViewModel}">
            <vw:ProjectInfoStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmw:FileImportStepViewModel}">
            <vw:FileImportStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmw:FileNamingStepViewModel}">
            <vw:FileNamingStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmw:MetadataFormStepViewModel}">
            <vw:MetadataFormStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmw:ReviewStepViewModel}">
            <vw:ReviewStepView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />   <!-- Step indicator bar -->
            <RowDefinition Height="*" />    <!-- Step content -->
            <RowDefinition Height="64" />   <!-- Navigation buttons -->
        </Grid.RowDefinitions>

        <!-- Step Indicator Bar -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryAccentBrush}">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="New Project  —  " FontSize="14" />
                <TextBlock Style="{StaticResource StepHeader}"
                           Text="{Binding StepLabel}" FontSize="14" />
            </StackPanel>
        </Border>

        <!-- Current Step Content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentStep}" />

        <!-- Navigation Buttons -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid>
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Left"
                        Padding="10,6">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Width="27" Height="27" Stretch="Uniform" Fill="Black"
                              Data="M61.44,0c33.926,0,61.44,27.514,61.44,61.44c0,33.926-27.514,61.439-61.44,61.439C27.513,122.88,0,95.366,0,61.44C0,27.514,27.513,0,61.44,0z M98.505,37.049L37.051,98.503c6.999,4.617,15.379,7.307,24.389,7.307c24.5,0,44.369-19.869,44.369-44.369C105.809,52.431,103.119,44.05,98.505,37.049z M24.378,85.829l61.453-61.454c-6.997-4.615-15.381-7.304-24.391-7.304c-24.5,0-44.369,19.87-44.369,44.369C17.072,70.449,19.761,78.83,24.378,85.829z" />
                        <TextBlock Text="Cancel"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="11"
                                   Foreground="Black"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding BackCommand}"
                            Margin="0,0,12,0"
                            Padding="10,6"
                            Visibility="{Binding IsFirstStep,
                                         Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="36" Height="36">
                                <Image Source="/Assets/previous.png"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                            </Grid>
                            <TextBlock Text="Back"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="11"
                                       Foreground="Black"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding NextCommand}"
                            Margin="0,0,12,0"
                            Padding="10,6"
                            Visibility="{Binding IsLastStep,
                                         Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="36" Height="36">
                                <Image Source="/Assets/Next.png"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                            </Grid>
                            <TextBlock Text="Next"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="11"
                                       Foreground="Black"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExitCommand}"
                            Padding="10,6">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="27" Height="27">
                                <Image Source="/Assets/Exit.png"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Rectangle Fill="#33000000" IsHitTestVisible="False" />
                            </Grid>
                            <TextBlock Text="Exit"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="11"
                                       Foreground="Black"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
